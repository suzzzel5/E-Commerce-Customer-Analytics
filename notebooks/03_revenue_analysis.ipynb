    "print(\"Revenue Analysis by membership Type \")\n",
    "print()\n",
    "\n",
    "membership_revenue = df.groupby(\"membership_type\").agg({\"total_spend\":[\"sum\",\"mean\",\"median\",\"count\"]}).round(2)\n",
    "# Flatten column names\n",
    "membership_revenue.columns = ['Total_Revenue', 'Avg_Spend', 'Median_Spend', 'Customer_Count']\n",
    "membership_revenue = membership_revenue.reset_index()\n",
    "\n",
    "# Calculate percentage of total revenue\n",
    "membership_revenue['Revenue_Percentage'] = (membership_revenue['Total_Revenue'] / membership_revenue['Total_Revenue'].sum() * 100).round(1)\n",
    "\n",
    "# Sort by total revenue (descending)\n",
    "membership_revenue = membership_revenue.sort_values('Total_Revenue', ascending=False)\n",
    "print(\"MEMBERSHIP TYPE COMPARISON:\")\n",
    "print()\n",
    "print(membership_revenue.to_string(index=False))\n",
    "print()\n",
    "\n",
    "\n",
    "# Key insights\n",
    "top_tier = membership_revenue.iloc[0]\n",
    "bottom_tier = membership_revenue.iloc[-1]\n",
    "\n",
    "\n",
    "print(f\"Top Tier: {top_tier['membership_type']}\")\n",
    "print(f\"Generates ${top_tier['Total_Revenue']:,.2f} ({top_tier['Revenue_Percentage']:.1f}% of total)\")\n",
    "# print(f\"{top_tier['Customer_Count']:.0f} customers ({top_tier['Customer_Percentage']:.1f}% of base)\")\n",
    "print(f\" Average spend: ${top_tier['Avg_Spend']:,.2f}\")\n",
    "print()\n",
    "\n",
    "print(f\"Bottom Tier: {bottom_tier['membership_type']}\")\n",
    "print(f\"Generates ${bottom_tier['Total_Revenue']:,.2f} ({bottom_tier['Revenue_Percentage']:.1f}% of total)\")\n",
    "# print(f\"{bottom_tier['Customer_Count']:.0f} customers ({bottom_tier['Customer_Percentage']:.1f}% of base)\")\n",
    "print(f\"Average spend: ${bottom_tier['Avg_Spend']:,.2f}\")\n",
    "print()\n",
    "\n"
   ]
  },
